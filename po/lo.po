#: pkcs11/gkm/gkm-certificate.c:578
msgid "Unnamed Certificate"
msgstr "ໃບຮັບຮອງບໍ່ມີຊື່"

#: pkcs11/ssh-store/gkm-ssh-private-key.c:341
msgid "Couldn’t parse public SSH key"
msgstr "ບໍ່ສາມາດວິເຄາະກະແຈສາທາລະນະ SSH ໄດ້"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:529
msgid "Unlock Login Keyring"
msgstr "ປົດລັອກກະແຈເຂົ້າສູ່ລະບົບ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:530
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:554
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:630
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:706
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1186
msgid "Authentication required"
msgstr "ຕ້ອງການການກວດສອບ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:533
msgid ""
"The password you use to log in to your computer no longer matches that of "
"your login keyring."
msgstr "ລະຫັດຜ່ານທີ່ທ່ານໃຊ້ເພື່ອເຂົ້າສູ່ລະບົບຄອມພິວເຕີຂອງທ່ານບໍ່ກົງກັບລະຫັດຜ່ານຂອງກະແຈເຂົ້າສູ່ລະບົບອີກຕໍ່ໄປ."

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:535
msgid ""
"The login keyring did not get unlocked when you logged into your computer."
msgstr "ກະແຈເຂົ້າສູ່ລະບົບບໍ່ໄດ້ຖືກປົດລັອກເມື່ອທ່ານເຂົ້າສູ່ລະບົບຄອມພິວເຕີຂອງທ່ານ."

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:553
msgid "Unlock Keyring"
msgstr "ປົດລັອກກະແຈ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:556
#, c-format
msgid "An application wants access to the keyring “%s”, but it is locked"
msgstr "ແອັບພລິເຄຊັນຕ້ອງການເຂົ້າເຖິງກະແຈ “%s”, ແຕ່ມັນຖືກລັອກຢູ່"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:562
msgid "Automatically unlock this keyring whenever I’m logged in"
msgstr "ປົດລັອກກະແຈນີ້ໂດຍອັດຕະໂນມັດທຸກຄັ້ງທີ່ຂ້ອຍເຂົ້າສູ່ລະບົບ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:575
msgid "Unlock certificate"
msgstr "ປົດລັອກໃບຮັບຮອງ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:577
msgid "Unlock public key"
msgstr "ປົດລັອກກະແຈສາທາລະນະ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:591
msgid "Automatically unlock this certificate whenever I’m logged in"
msgstr "ປົດລັອກໃບຮັບຮອງນີ້ໂດຍອັດຕະໂນມັດທຸກຄັ້ງທີ່ຂ້ອຍເຂົ້າສູ່ລະບົບ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:593
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:715
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1076
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1225
msgid "Automatically unlock whenever I’m logged in"
msgstr "ປົດລັອກອັດຕະໂນມັດທຸກຄັ້ງທີ່ຂ້ອຍເຂົ້າສູ່ລະບົບ"

#. TRANSLATORS: The certificate is locked
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:607
#, c-format
msgid "An application wants access to the certificate “%s”, but it is locked"
msgstr "ແອັບພລິເຄຊັນຕ້ອງການເຂົ້າເຖິງໃບຮັບຮອງ “%s”, ແຕ່ມັນຖືກລັອກຢູ່"

#. TRANSLATORS: The public key is locked
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:610
#, c-format
msgid "An application wants access to the public key “%s”, but it is locked"
msgstr "ແອັບພລິເຄຊັນຕ້ອງການເຂົ້າເຖິງກະແຈສາທາລະນະ “%s”, ແຕ່ມັນຖືກລັອກຢູ່"

#. TRANSLATORS: The object '%s' is locked
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:613
#, c-format
msgid "An application wants access to “%s”, but it is locked"
msgstr "ແອັບພລິເຄຊັນຕ້ອງການເຂົ້າເຖິງ “%s”, ແຕ່ມັນຖືກລັອກຢູ່"

#. Build up the prompt
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:705
msgid "Unlock certificate/key storage"
msgstr "ປົດລັອກບ່ອນເກັບໃບຮັບຮອງ/ກະແຈ"

#. TRANSLATORS: The storage is locked, and needs unlocking before the application can use it.
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:709
#, c-format
msgid ""
"An application wants access to the certificate/key storage “%s”, but it is "
"locked"
msgstr "ແອັບພລິເຄຊັນຕ້ອງການເຂົ້າເຖິງບ່ອນເກັບໃບຮັບຮອງ/ກະແຈ “%s”, ແຕ່ມັນຖືກລັອກຢູ່"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1067
msgid "New Password Required"
msgstr "ຕ້ອງການລະຫັດຜ່ານໃໝ່"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1068
msgid "New password required"
msgstr "ຕ້ອງການລະຫັດຜ່ານໃໝ່"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1070
#, c-format
msgid ""
"In order to prepare “%s” for storage of certificates or keys, a password is "
"required"
msgstr "ເພື່ອທີ່ຈະກະກຽມ “%s” ສຳລັບການເກັບໃບຮັບຮອງ ຫຼື ກະແຈ, ຕ້ອງມີລະຫັດຜ່ານ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1185
#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1216
msgid "Change Password"
msgstr "ປ່ຽນລະຫັດຜ່ານ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1188
#, c-format
msgid "To change the password for “%s”, the original password is required"
msgstr "ເພື່ອປ່ຽນລະຫັດຜ່ານສຳລັບ “%s”, ຕ້ອງໃຊ້ລະຫັດຜ່ານເດີມ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1217
msgid "Change password"
msgstr "ປ່ຽນລະຫັດຜ່ານ"

#: pkcs11/wrap-layer/gkm-wrap-prompt.c:1219
#, c-format
msgid "Type a new password for “%s”"
msgstr "ພິມລະຫັດຜ່ານໃໝ່ສຳລັບ “%s”"

#: tool/gkr-tool.c:100
msgid "usage: gnome-keyring command [options]\n"
msgstr "ການນຳໃຊ້: gnome-keyring ຄຳສັ່ງ [ຕົວເລືອກ]\n"

